# ─────────────────────────────────────────────────────────────────────────────
# MarketPulse AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Bright Data ───────────────────────────────────────────────────────────────
# API Token — from Account Settings → API Tokens (used by Web Scraper API + MCP)
BRIGHTDATA_API_KEY=your_api_token_here

# Customer ID — shown top-right in dashboard after clicking your avatar
BRIGHTDATA_CUSTOMER_ID=hl_xxxxxxxxxx

# Zone names — set when you created each zone in the dashboard
SERP_ZONE=serp_hackathon
UNLOCKER_ZONE=web_unlocker_main
SCRAPING_BROWSER_ZONE=scraping_browser_hk

# Zone passwords — from each zone's Access parameters tab
SERP_PASSWORD=xxxxxxxxxxxxxxxxxxxx
UNLOCKER_PASSWORD=xxxxxxxxxxxxxxxxxxxx
BROWSER_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# Proxy host and ports (these don't change)
PROXY_HOST=brd.superproxy.io
PROXY_PORT=33335
BROWSER_CDP_PORT=9222

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Claude API key — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── App settings ──────────────────────────────────────────────────────────────
# Flask
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=change_this_to_a_random_string

# Cache: how long to keep an intelligence object before re-running (seconds)
CACHE_TTL_SECONDS=3600

# Pipeline: max companies to process in parallel
MAX_PARALLEL_COMPANIES=3

# ── Optional: Slack alerts ────────────────────────────────────────────────────
# Paste your Slack webhook URL to enable high-confidence signal alerts
SLACK_WEBHOOK_URL=

# ── Optional: Demo seed data ──────────────────────────────────────────────────
# Comma-separated list of tickers to pre-load on server start
SEED_TICKERS=AAPL,MSFT,GOOGL
